{
  "expo": {
    "name": "FinSmart",
    "slug": "finsmart",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0D1117",
    "splash": {
      "backgroundColor": "#0D1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.finsmart.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "FinSmart uses your location to show localised exchange schedules and market hours."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D1117"
      },
      "package": "com.finsmart.app",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "FinSmart uses your location to show localised exchange schedules."
        }
      ]
    ]
  }
}
